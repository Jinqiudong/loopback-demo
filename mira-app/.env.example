# Slack app credentials
# Get these from https://api.slack.com/apps -> your app -> OAuth & Permissions / Basic Information
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# Anthropic API key for intent classification and answer extraction
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Set to true to skip the real Knowledge Vault package and use local stubs.
# Useful when knowledge_vault isn't installed yet (teammate's package).
VAULT_STUB=true
